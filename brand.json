    "body":    { "family": "Outfit", "weights": [400, 500, 600, 700], "italics": false },
    "mono":    { "family": "JetBrains Mono", "weights": [400, 500, 600], "italics": false }
  },

  "logos": {
    "dark": "data:image/png;base64,COPY_FROM_INDEX_HTML_LOGO_DARK_CONSTANT",
    "light": "data:image/png;base64,COPY_FROM_INDEX_HTML_LOGO_LIGHT_CONSTANT"
  },

  "wordmark": {
    "html": "traent<span class=\"dot\">.</span>hub",
