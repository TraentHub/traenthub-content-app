    }
  },

  "emphasisDevices": {
    "underline_pop":      { "label": "Underline accent" },
    "italic_pop":         { "label": "Italic accent" },
    "strike_muted":       { "label": "Strikethrough" },
    "outline":            { "label": "Outline" },
