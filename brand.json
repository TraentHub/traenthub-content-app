      "desc": "Poster logic, grande claim tipografico, forte presenza editoriale.",
      "preview": "Non cerchiamo\nspazi."
    },
    "Editorial": {
      "desc": "Più bilanciato, leggibile, claim + supporto + asset pulito.",
      "preview": "Una selezione\nrigorosa."
    },
    "Energetic": {
      "desc": "Più contrastato, adatto per launch, event, closing slide.",
      "preview": "Nuove\nprospettive."
    },
    "Institutional-light": {
      "desc": "Sobrio, ordinato, per contesti informativi e istituzionali.",
